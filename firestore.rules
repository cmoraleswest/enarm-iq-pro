rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Perfil de usuario — solo el dueño puede leer/escribir
    match /users/{uid} {
      allow read, update, delete: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null;
    }

    // Sesiones de examen — solo el dueño puede leer
    match /examSessions/{sessionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Sesiones pendientes — solo Admin SDK
    match /pendingSessions/{doc} {
      allow read, write: if false;
    }

    // Influencers — solo Admin SDK
    match /influencers/{doc} {
      allow read, write: if false;
    }
  }
}
